// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MerchantStatus {
  active
  inactive
}

enum Currency {
  GTQ
  COP
  USD
}

enum TransactionType {
  payin
  payout
}

enum TransactionStatus {
  pending
  approved
  rejected
  failed
  completed
}

enum SettlementStatus {
  pending
  processed
  paid
}

model Merchant {
  id     String         @id @default(uuid()) @db.Uuid
  name   String
  email  String         @unique
  apiKey String         @unique @map("api_key")
  status MerchantStatus @default(active)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transactions Transaction[]
  settlements  Settlement[]

  @@index([status])
  @@map("merchants")
}

model Transaction {
  id String @id @default(uuid()) @db.Uuid

  merchantId String   @map("merchant_id") @db.Uuid
  merchant   Merchant @relation(fields: [merchantId], references: [id])

  amount Decimal @db.Decimal(12, 2)

  currency Currency
  type     TransactionType
  status   TransactionStatus @default(pending)

  reference String @unique
  metadata  Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  settlementTransaction SettlementTransaction?

  @@index([merchantId])
  @@index([status])
  @@index([createdAt])
  @@index([merchantId, status])
  @@index([merchantId, createdAt])
  @@map("transactions")
}

model Settlement {
  id String @id @default(uuid()) @db.Uuid

  merchantId String   @map("merchant_id") @db.Uuid
  merchant   Merchant @relation(fields: [merchantId], references: [id])

  totalAmount      Decimal @map("total_amount") @db.Decimal(14, 2)
  transactionCount Int     @map("transaction_count")

  status SettlementStatus @default(pending)

  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")

  createdAt DateTime @default(now()) @map("created_at")

  settlementTransactions SettlementTransaction[]

  @@index([merchantId])
  @@index([status])
  @@index([periodStart, periodEnd])
  @@index([merchantId, periodStart, periodEnd])
  @@index([merchantId, status])
  @@map("settlements")
}

model SettlementTransaction {
  settlementId  String @map("settlement_id") @db.Uuid
  transactionId String @unique @map("transaction_id") @db.Uuid

  settlement  Settlement  @relation(fields: [settlementId], references: [id])
  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@id([settlementId, transactionId])
  @@map("settlement_transactions")
}
